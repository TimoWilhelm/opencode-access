# Required Cloudflare account configuration for `npm run setup`
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
TEAM_DOMAIN=https://your-team.cloudflareaccess.com

CUSTOM_HOSTNAME=opencode.example.com
CLOUDFLARE_ZONE_ID=

# Optional deployment overrides.
WORKER_NAME=opencode-access
AIG_GATEWAY_ID=opencode-access
AIG_AUTH_TOKEN=
AIG_LOG_PAYLOADS=false
OPENCODE_PROVIDER_ID=cloudflare-access-gateway
OPENCODE_PROVIDER_NAME=Cloudflare Access Gateway

# Auto-populated by `npm run setup`.
POLICY_AUD=
WORKER_URL=
DISCOVERY_URL=
AIG_AUTH_TOKEN_ID=
USER_DB_ID=
USER_DB_NAME=
CONFIG_CACHE_KV_ID=
